---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import FaqSection from '../../../components/FaqSection.astro';
import CtaBarFinal from '../../../components/CtaBarFinal.astro';
import GallerySection from '../../../components/GallerySection.astro';

const galeriaImages = [
  { src: "/img/boda-hacienda-1.avif", alt: "Mesa larga de madera decorada con rosas blancas y luces cálidas en hacienda al atardecer" },
  { src: "/img/boda-boho-1.avif", alt: "Vista cenital de mesa picnic con decoración bohemia, pampas y platos de terracota" },
  { src: "/img/boda-multiples-1.avif", alt: "Múltiples mesas de madera alineadas para recepción en jardín con luces de hada" },
  { src: "/img/boda-detalle-1.avif", alt: "Detalle de lugar con plato de porcelana, copa de cristal y servilleta con romero" },
  { src: "/img/mesa-picnic-recepcion-boda-jardin.webp", alt: "Recepción de boda en jardín con bancas de madera y flores naturales" },
  { src: "/img/mesa-picnic-boda-elegante-luces.webp", alt: "Banca de madera con iluminación cálida nocturna para boda elegante" },
  { src: "/img/mesa-picnic-recepcion-boda-jardin-02.webp", alt: "Bancas rústicas con centros de mesa florales en recepción al aire libre" },
  { src: "/img/mesa-picnic-boda-invitados-atardecer.webp", alt: "Mobiliario de madera con vista al atardecer preparado para ceremonia" },
  { src: "/img/mesa-picnic-recepcion-boda-jardin-03.webp", alt: "Disposición de mesas largas para banquete nupcial en jardín" },
  { src: "/img/mesa-picnic-romantica-velas-rosas.webp", alt: "Banca decorada con velas y rosas para cena romántica al aire libre" },
  { src: "/img/mesa-picnic-romantica-vinedo-atardecer.webp", alt: "Mesa de madera en viñedo con copas de vino al atardecer dorado" },
  { src: "/img/mesa-picnic-recepcion-nocturna-luces.webp", alt: "Recepción nocturna con bancas iluminadas por series de luces" },
];
---

<BaseLayout
  title="Mesas Picnic para Bodas al Aire Libre en CDMX | MESPIC"
  description="Renta de bancas de madera para bodas en jardines, haciendas y terrazas. Piezas de pino barnizadas a mano, 2.4 m para 6-8 personas. Entrega y montaje incluidos en CDMX y Edomex."
>

<!-- Breadcrumbs -->
<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Servicios", href: "/servicios/" },
    { label: "Bodas" }
  ]} />
</Fragment>

<!-- Hero -->
<Hero
  badge="Servicio para bodas"
  title="Bancas de Madera para Bodas al Aire Libre"
  description="Mobiliario de pino natural barnizado a mano para ceremonias y recepciones en jardines, haciendas y terrazas. De 10 a 300 invitados, con montaje incluido."
  ctaPrimary={{ label: "Ver catálogo de mesas →", href: "/catalogo/" }}
  ctaSecondary={{ label: "Ver paquetes", href: "/paquetes/" }}
  seoParagraph1="En más de 200 bodas al aire libre hemos trabajado junto a wedding planners y parejas en la Ciudad de México y Estado de México. Desde ceremonias íntimas de 10 personas en jardines privados de Coyoacán hasta recepciones de 300 invitados en haciendas de Edomex. Cada banca mide 2.4 metros de largo, acomoda de 6 a 8 personas y se entrega lijada y barnizada a tres manos."
  seoParagraph2="La madera de pino tratado combina naturalmente con decoración rústica, boho, provenzal, minimalista o clásica — no necesitas forrar ni ocultar la estructura. Las bancas integradas eliminan la necesidad de rentar sillas por separado, lo que reduce costos y simplifica la logística de tu boda."
/>

<!-- Qué incluye -->
<section class="section" id="que-incluye">
  <SectionHeader
    tag="h2"
    title="Qué Incluye el Servicio para Bodas"
    paragraph1="Todo lo que necesitas para que el mobiliario de tu boda esté listo sin que tú ni tu familia muevan una sola pieza. Nuestro equipo se encarga de la logística completa."
    paragraph2="Coordinamos directamente con tu wedding planner o decoradora para definir la disposición de las bancas, los pasillos de circulación y los puntos de iluminación antes del día del evento."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Entrega en tu Venue" description="Llegamos al jardín, hacienda o terraza entre 3 y 4 horas antes de la ceremonia. Cubrimos todas las alcaldías de CDMX y municipios del Edomex como Naucalpan, Huixquilucan y Atizapán." />
      <FeatureCard title="Montaje según Plano" description="Colocamos cada banca según el plano acordado con tu planner. Definimos pasillos de circulación, zona de banquete, área de ceremonia y rincones de foto." />
      <FeatureCard title="Sin Límite de Hora" description="Las bancas quedan en tu boda hasta que termine. Si la fiesta acaba a las 3 am, recogemos a las 3 am. No cobramos tiempo extra." />
      <FeatureCard title="Recolección al Terminar" description="Al día siguiente o al finalizar el evento, nuestro equipo recoge todo el mobiliario. El precio incluye este servicio — sin cargos adicionales." />
    </div>
  </div>
</section>

<!-- Estilos de boda -->
<section class="section section-alt" id="estilos">
  <SectionHeader
    tag="h2"
    title="Un Lienzo para Cualquier Estilo de Boda"
    paragraph1="La madera sin pintar funciona como base neutra: acepta caminos de tela, guirnaldas de eucalipto, portavelas de latón o arreglos minimalistas con la misma naturalidad."
    paragraph2="Hemos montado desde bodas boho en bosques del Estado de México hasta recepciones provenzales en azoteas de Polanco. La madera se adapta, tú decides el estilo."
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard title="Boda Rústica" description="Madera al natural con flores silvestres, velas y caminos de yute. El estilo más popular para jardines y haciendas. Combina con iluminación cálida de serie de luces." image="/img/mesa-picnic-boda-elegante-decoracion.webp" href="/servicios/bodas/rustica/" btnLabel="Boda rústica" />
      <ServiceCard title="Boda Boho" description="Pampas, macramé y telas naturales sobre las bancas. Ideal para bosques, viñedos y espacios al aire libre con vegetación. Las bancas de pino complementan la estética orgánica." image="/img/mesa-picnic-boda-elegante-decoracion.webp" href="/catalogo/mesa-picnic-estandar/" btnLabel="Mesa estándar" />
      <ServiceCard title="Boda Clásica" description="Manteles de lino, vajilla de porcelana y centros de mesa con rosas. La superficie lisa de la banca soporta montajes formales sin problema. Para 50 a 300 invitados." image="/img/mesa-picnic-boda-elegante-decoracion.webp" href="/catalogo/mesa-picnic-grande/" btnLabel="Mesa grande" />
      <ServiceCard title="Boda Íntima" description="Montaje para 10 a 30 personas con 2 a 5 bancas. Perfecto para ceremonias civiles en jardines privados, terrazas o restaurantes con área exterior." image="/img/mesa-picnic-boda-elegante-decoracion.webp" href="/paquetes/basico/" btnLabel="Paquete básico" />
    </div>
  </div>
</section>

<!-- Datos concretos -->
<section class="section" id="datos">
  <SectionHeader
    tag="h2"
    title="Datos que Necesitas para Planear"
    paragraph1="Estas son las especificaciones técnicas del mobiliario y las referencias de cantidad que usamos para calcular tu cotización."
    paragraph2="Si no estás segura de cuántas bancas necesitas, mándanos tu número de invitados y el plano del venue por WhatsApp y te calculamos todo."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Mesa Estándar: 6-8 Personas" description="Mide 1.80 × 1.50 m. La más versátil para bodas. Para 100 invitados necesitas aproximadamente 14-16 unidades." />
      <FeatureCard title="Mesa Grande: 10-12 Personas" description="Mide 2.40 × 1.50 m. Ideal para mesas largas tipo banquete. Para 100 invitados necesitas 9-10 unidades." />
      <FeatureCard title="Acabado a Tres Manos" description="Cada pieza se lija a grano fino y barniza tres veces. Superficie lisa, sin astillas, segura para manteles y vajilla fina." />
      <FeatureCard title="Peso y Resistencia" description="Pino nacional seleccionado, tratado contra humedad. Soporta uso intensivo todo el día. La madera resiste lluvia moderada con carpa." />
    </div>
  </div>
</section>

<!-- Galería de bodas -->
<section class="section" id="galeria-bodas">
  <div class="container">
    <h2 style="text-align:center; margin-bottom:0.5rem;">Nuestro Mobiliario en Bodas Reales</h2>
    <p style="text-align:center; color:var(--text-muted); margin-bottom:2rem;">Montajes para ceremonias y recepciones en jardines, haciendas y terrazas de la Ciudad de México y Edomex.</p>
  </div>
  <GallerySection images={galeriaImages} id="galeria" />
</section>

<!-- FAQ bodas -->
<section class="section" id="faq">
  <SectionHeader
    tag="h2"
    title="Preguntas sobre Bodas"
    paragraph1="Las dudas más comunes que recibimos de parejas y wedding planners antes de reservar el mobiliario para su boda."
    paragraph2="Si tu pregunta no está aquí, escríbenos por WhatsApp y te respondemos en minutos."
  />
  <FaqSection
    phone="55 3128 1706"
    whatsapp="5531281706"
    schedule="Lun–Dom 8:00–20:00"
    items={[
      { question: "¿Cuántas bancas necesito para mi boda?", answer: "Cada banca estándar sienta 6-8 personas. Para 100 invitados necesitas 14-16 unidades, para 150 necesitas 20-22, para 200 necesitas 28-30. Mándanos tu número de invitados y te calculamos la cantidad exacta." },
      { question: "¿Combinan con decoración elegante?", answer: "Sí. La madera de pino acepta manteles de lino, vajilla de porcelana, candelabros y centros de mesa con flores sin desentonar. Tenemos fotos de montajes formales en nuestra galería." },
      { question: "¿Entregan en haciendas fuera de la ciudad?", answer: "Cubrimos toda la zona metropolitana y municipios del Estado de México. Para haciendas más lejanas, escríbenos la ubicación y confirmamos disponibilidad y costo de traslado." },
      { question: "¿Pueden coordinarse con mi wedding planner?", answer: "Sí, trabajamos directo con tu planner o decoradora. Les enviamos las medidas de cada pieza y coordinamos el plano de distribución antes del evento." },
      { question: "¿Qué pasa si llueve el día de mi boda?", answer: "La madera está tratada y resiste humedad moderada. Recomendamos contar con carpas o toldos como plan B. Si cancelas por clima, puedes reagendar sin costo adicional." },
      { question: "¿Puedo ver las bancas antes de reservar?", answer: "Sí, puedes agendar una visita a nuestro almacén para ver el mobiliario en persona. También te mandamos fotos y video del estado actual de las piezas por WhatsApp." }
    ]}
  />
</section>

<!-- CTA Final — nivel 2, aquí sí contacto directo -->
<CtaBarFinal
  headline="¿Lista para tu boda?"
  subtext="Cotiza el mobiliario para tu fecha. Te respondemos el mismo día."
  phone="55 3128 1706"
  whatsapp="5531281706"
  waMessage="Hola, quiero cotizar mesas picnic para mi boda."
  cotizarHref="/cotizar/"
/>

<!-- Schemas -->
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Mesas Picnic para Bodas",
    "provider": {
      "@type": "LocalBusiness",
      "name": "MESPIC",
      "telephone": "+52-55-3128-1706"
    },
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "description": "Renta de bancas de madera de pino para bodas al aire libre en CDMX y Edomex. Incluye entrega, montaje y recolección.",
    "offers": {
      "@type": "Offer",
      "priceCurrency": "MXN",
      "availability": "https://schema.org/InStock"
    }
  })} />
</Fragment>

</BaseLayout>

<style>
  :global(.hero) {
    padding-top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2.5rem + 3rem);
  }

  .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 1024px) {
    .grid-4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .grid-4 { grid-template-columns: 1fr; }
  }
</style>
